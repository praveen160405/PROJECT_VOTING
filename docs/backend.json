{
  "entities": {
    "Vote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Vote",
      "type": "object",
      "description": "A cryptographic audit receipt of a vote cast on the OOTU protocol ledger.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Internal protocol reference ID."
        },
        "voterId": {
          "type": "string",
          "description": "Reference to the voter's decentralized identity."
        },
        "candidateId": {
          "type": "string",
          "description": "The ID of the candidate who received the vote."
        },
        "electionId": {
          "type": "string",
          "description": "The specific election protocol window."
        },
        "timestamp": {
          "type": "string",
          "description": "Block timestamp of the transaction.",
          "format": "date-time"
        },
        "isVerified": {
          "type": "boolean",
          "description": "Confirmation status on the decentralized network."
        },
        "txHash": {
          "type": "string",
          "description": "The immutable digital audit hash (Primary Audit Key)."
        }
      },
      "required": [
        "voterId",
        "candidateId",
        "electionId",
        "timestamp",
        "isVerified",
        "txHash"
      ]
    },
    "Voter": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Voter",
      "type": "object",
      "description": "Voter profile used for forensic identity verification before ledger access.",
      "properties": {
        "id": { "type": "string" },
        "voterId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "aadharNumber": { "type": "string" },
        "faceImageHash": { "type": "string", "description": "Base64 encoded reference biometric capture." },
        "isAdmin": { "type": "boolean" },
        "region": { "type": "string" },
        "age": { "type": "number" }
      },
      "required": [
        "id",
        "voterId",
        "email",
        "firstName",
        "lastName"
      ]
    },
    "Election": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Election",
      "type": "object",
      "description": "Configuration for an active protocol window.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "candidateIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": [ "name", "startDate", "endDate" ]
    }
  },
  "auth": {
    "providers": [ "password" ]
  },
  "firestore": {
    "/users/{userId}/votes/{voteId}": {
      "schema": { "$ref": "#/backend/entities/Vote" },
      "description": "Stores digital audit receipts for voter auditing."
    },
    "/elections/{electionId}": {
      "schema": { "$ref": "#/backend/entities/Election" },
      "description": "Configuration for active protocol windows."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/Voter" },
      "description": "Voter profile and biometric identity data."
    }
  }
}