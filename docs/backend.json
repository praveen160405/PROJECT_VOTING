
{
  "entities": {
    "Vote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Vote",
      "type": "object",
      "description": "Represents a single vote cast in an election.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the vote entity."
        },
        "voterId": {
          "type": "string",
          "description": "Reference to Voter. (Relationship: Voter 1:N Vote)"
        },
        "candidateId": {
          "type": "string",
          "description": "Reference to Candidate. (Relationship: Candidate 1:N Vote)"
        },
        "electionId": {
          "type": "string",
          "description": "Reference to Election. (Relationship: Election 1:N Vote)"
        },
        "timestamp": {
          "type": "string",
          "description": "The date and time when the vote was cast.",
          "format": "date-time"
        },
        "isVerified": {
          "type": "boolean",
          "description": "Indicates whether the vote has been verified."
        }
      },
      "required": [
        "id",
        "voterId",
        "candidateId",
        "electionId",
        "timestamp",
        "isVerified"
      ]
    },
    "Voter": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Voter",
      "type": "object",
      "description": "Represents a registered voter.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the voter entity (Firebase Auth UID)."
        },
        "voterId": {
          "type": "string",
          "description": "The voter's unique identification string used for login."
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the voter."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the voter."
        },
        "aadharNumber": {
          "type": "string",
          "description": "The 12-digit Aadhar number of the voter for identity verification."
        },
        "faceImageHash": {
          "type": "string",
          "description": "Hash of the voter's facial image."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Indicates whether the user has administrative privileges."
        },
        "region": {
          "type": "string",
          "description": "The geographic region of the voter.",
          "enum": ["North", "South", "East", "West"]
        },
        "age": {
          "type": "number",
          "description": "The age of the voter."
        }
      },
      "required": [
        "id",
        "voterId",
        "firstName",
        "lastName",
        "aadharNumber"
      ]
    },
    "Candidate": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Candidate",
      "type": "object",
      "description": "Represents a candidate in an election.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the candidate entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the candidate."
        },
        "party": {
          "type": "string",
          "description": "The political party of the candidate."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL of the candidate's image.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "name",
        "party",
        "imageUrl"
      ]
    },
    "Election": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Election",
      "type": "object",
      "description": "Represents an election event.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the election entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the election."
        },
        "startDate": {
          "type": "string",
          "description": "The start date and time of the election.",
          "format": "date-time"
        },
        "endDate": {
          "type": "string",
          "description": "The end date and time of the election.",
          "format": "date-time"
        },
        "candidateIds": {
          "type": "array",
          "description": "References to Candidates participating in this election. (Relationship: Election 1:N Candidate)",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "name",
        "startDate",
        "endDate",
        "candidateIds"
      ]
    },
    "Threat": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Threat",
      "type": "object",
      "description": "Represents a detected security threat or attack attempt.",
      "properties": {
        "id": {
          "type": "string"
        },
        "ipAddress": {
          "type": "string",
          "description": "IP address of the origin of the attack."
        },
        "type": {
          "type": "string",
          "description": "The type of attack (e.g., SQL Injection, Brute Force)."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "string",
          "description": "The suspicious input or payload detected."
        }
      },
      "required": [
        "ipAddress",
        "type",
        "timestamp"
      ]
    },
    "BlockedIp": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BlockedIp",
      "type": "object",
      "description": "Represents a banned IP address.",
      "properties": {
        "ip": {
          "type": "string",
          "description": "The IP address that is blocked."
        },
        "reason": {
          "type": "string",
          "description": "Reason for the block."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "ip",
        "timestamp"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/votes/{voteId}",
        "definition": {
          "entityName": "Vote",
          "schema": {
            "$ref": "#/backend/entities/Vote"
          },
          "description": "Stores individual votes cast by a voter.",
          "params": [
            {
              "name": "userId",
              "description": "The ID of the voter."
            },
            {
              "name": "voteId",
              "description": "The ID of the vote."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "Voter",
          "schema": {
            "$ref": "#/backend/entities/Voter"
          },
          "description": "Stores the details of the user.",
          "params": [
            {
              "name": "userId",
              "description": "The ID of the user."
            }
          ]
        }
      },
      {
        "path": "/elections/{electionId}",
        "definition": {
          "entityName": "Election",
          "schema": {
            "$ref": "#/backend/entities/Election"
          },
          "description": "Stores information about an election.",
          "params": [
            {
              "name": "electionId",
              "description": "The ID of the election."
            }
          ]
        }
      },
      {
        "path": "/candidates/{candidateId}",
        "definition": {
          "entityName": "Candidate",
          "schema": {
            "$ref": "#/backend/entities/Candidate"
          },
          "description": "Stores information about a candidate.",
          "params": [
            {
              "name": "candidateId",
              "description": "The ID of the candidate."
            }
          ]
        }
      },
      {
        "path": "/threats/{threatId}",
        "definition": {
          "entityName": "Threat",
          "schema": {
            "$ref": "#/backend/entities/Threat"
          },
          "description": "Logged security incidents and attack attempts.",
          "params": [
            {
              "name": "threatId",
              "description": "Unique ID for the threat record."
            }
          ]
        }
      },
      {
        "path": "/blockedIps/{ipId}",
        "definition": {
          "entityName": "BlockedIp",
          "schema": {
            "$ref": "#/backend/entities/BlockedIp"
          },
          "description": "List of blocked IP addresses.",
          "params": [
            {
              "name": "ipId",
              "description": "The ID of the blocked IP (usually the IP itself)."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore data structure is optimized for security and real-time monitoring. The 'threats' collection allows for centralized logging of suspicious activity, while 'blockedIps' provides a scalable way to ban malicious clients."
  }
}
