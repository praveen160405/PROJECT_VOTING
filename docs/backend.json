
{
  "entities": {
    "Vote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Vote",
      "type": "object",
      "description": "A cryptographic audit receipt of a vote cast on the blockchain ledger.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Internal OOTU reference ID."
        },
        "voterId": {
          "type": "string",
          "description": "Reference to the voter's decentralized identity."
        },
        "candidateId": {
          "type": "string",
          "description": "The ID of the candidate who received the vote."
        },
        "electionId": {
          "type": "string",
          "description": "The specific election protocol window."
        },
        "timestamp": {
          "type": "string",
          "description": "Block timestamp of the transaction.",
          "format": "date-time"
        },
        "isVerified": {
          "type": "boolean",
          "description": "Confirmation status on the decentralized network."
        },
        "txHash": {
          "type": "string",
          "description": "The immutable SHA-256 blockchain transaction hash (Primary Audit Key)."
        }
      },
      "required": [
        "id",
        "voterId",
        "candidateId",
        "electionId",
        "timestamp",
        "isVerified",
        "txHash"
      ]
    },
    "Voter": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Voter",
      "type": "object",
      "description": "Voter profile used for identity verification before blockchain access.",
      "properties": {
        "id": {
          "type": "string"
        },
        "voterId": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "aadharNumber": {
          "type": "string"
        },
        "faceImageHash": {
          "type": "string"
        },
        "isAdmin": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "voterId",
        "email",
        "firstName",
        "lastName"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/votes/{voteId}",
        "definition": {
          "entityName": "Vote",
          "schema": {
            "$ref": "#/backend/entities/Vote"
          },
          "description": "Stores blockchain transaction receipts for voter auditing."
        }
      },
      {
        "path": "/elections/{electionId}",
        "definition": {
          "entityName": "Election",
          "schema": {
            "$ref": "#/backend/entities/Election"
          },
          "description": "Configuration for active protocol windows."
        }
      }
    ]
  }
}
