rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read their own profile.
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      // Allow creation of user profile during sign-up.
      allow create: if request.auth != null;
    }

    // For the admin panel to work, admins need to be able to list users, 
    // update the isVerified status, and delete users.
    // For now, allow any authenticated user these permissions on the users collection.
    // This should be locked down with custom claims in a real app.
    match /users/{userId} {
      allow list, write: if request.auth != null;
    }
  }
}
