rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    // This is the collection group query rule.
    // It allows any signed-in user to query the 'votes' collection group.
    // This is needed for the results page to show aggregate data.
    match /{path=**}/votes/{voteId} {
      // We only allow 'list' (queries). We do not allow 'get' (direct doc reads).
      // Direct reads are handled by the more specific rule below.
      allow list: if isSignedIn();
    }

    // Votes - A user can create their own vote, and read their own vote.
    // Votes are immutable once created.
    match /users/{userId}/votes/{voteId} {
      // This rule handles direct document access (get) and writes (create).
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.voterId == userId;
      allow update, delete: if false; // Votes are immutable
    }

    // Public collections
    match /elections/{electionId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /candidates/{candidateId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
