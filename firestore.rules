rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow user to create their own profile during sign-up.
      // request.auth.uid is available after createUserWithEmailAndPassword completes.
      allow create: if request.auth != null && request.auth.uid == userId;

      // Users can read and update their own profile.
      allow read, update: if request.auth != null && request.auth.uid == userId;
      
      // For the admin panel to work, any authenticated user can list all users,
      // update any user's profile (e.g. verify them), and delete them.
      // This is insecure for production and should be replaced with custom claims.
      allow list, delete: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
